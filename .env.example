ACADEMY_API_PORT=8787
ACADEMY_API_HOST=127.0.0.1
CORS_ALLOWED_ORIGINS=*
VITE_API_BASE_URL=http://127.0.0.1:8787

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Production deployment
RENDER_API_URL=https://your-render-service.onrender.com
ACADEMY_API_URL=https://your-render-service.onrender.com
VERCEL_FRONTEND_URL=https://your-vercel-project.vercel.app

# SOLAPI Kakao Alimtalk
SOLAPI_API_KEY=your_solapi_api_key
SOLAPI_API_SECRET=your_solapi_api_secret
SOLAPI_FROM=01012345678
SOLAPI_PFID=your_kakao_channel_pfid
SOLAPI_ATTENDANCE_TEMPLATE_ID=your_attendance_template_id
SOLAPI_DAILY_REPORT_TEMPLATE_ID=your_daily_report_template_id
SOLAPI_STUDENT_COMMENT_TEMPLATE_ID=your_student_comment_template_id

# true disables fallback SMS.
SOLAPI_DISABLE_SMS=false

# true or unset means the API validates payloads without sending real Alimtalk.
ALIMTALK_DRY_RUN=true

# Allows template-test buttons to send real Alimtalk only to ALIMTALK_TEST_RECIPIENT.
ALIMTALK_ALLOW_LIVE_TEST_SEND=false

# Safety switch: by default every Alimtalk is redirected to this test number.
ALIMTALK_TEST_RECIPIENT=01057882748
ALIMTALK_ALLOW_REAL_PARENT_NUMBERS=false

# Slack morning teacher summary
SLACK_WEBHOOK_URL=your_slack_incoming_webhook_url
SLACK_DRY_RUN=true

# Exam analysis / lesson comment AI providers
OPENAI_API_KEY=your_openai_api_key
OPENAI_EXAM_ANALYSIS_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_EXAM_ANALYSIS_MODEL=claude-sonnet-4-5
