{
  "schemaVersion": 1,
  "principles": {
    "styleIsSeparateFromRole": true,
    "humanConfirmedDataOnly": true,
    "sourceMathMustNotBeRedrawn": true,
    "editablePromptOutput": true
  },
  "roles": {
    "cover": {
      "purpose": "학교·학년·시험을 즉시 식별시키는 첫 장",
      "requiredData": ["schoolName", "grade", "examName", "subject"],
      "layout": "hero_cover",
      "components": ["brand_header", "hero_title", "school_exam_meta", "visual_anchor"],
      "assetPolicy": "생성 가능. 로고는 제공 자산을 합성하고 모델이 새 로고를 만들지 않는다.",
      "qualityChecks": ["학교명·학년·시험명 오탈자 없음", "제목 위계 명확", "본문 분석 수치 없음"]
    },
    "exam_structure": {
      "purpose": "문항 수·배점·범위·서술형 구조를 한눈에 요약",
      "requiredData": ["questionCount", "scoreStructure", "scope"],
      "layout": "metric_dashboard",
      "components": ["section_title", "metric_cards", "structure_summary", "brand_footer"],
      "assetPolicy": "정확한 숫자는 코드 텍스트 레이어 또는 후편집 우선.",
      "qualityChecks": ["입력 숫자와 1:1 일치", "확정되지 않은 평균·등급컷 금지", "카드 3~5개 이내"]
    },
    "unit_distribution": {
      "purpose": "단원별 출제 문항·배점 비중을 비교",
      "requiredData": ["unitRows"],
      "layout": "chart_or_distribution",
      "components": ["section_title", "distribution_chart", "unit_labels", "interpretation_note"],
      "assetPolicy": "차트는 Academy OS 코드 렌더 우선, GPT Image는 배경·프레임만 생성.",
      "qualityChecks": ["합계 검산", "단원명 원문 유지", "범례와 색상 일치"]
    },
    "difficulty_flow": {
      "purpose": "쉬운 구간과 변별 구간, 시간 압박의 흐름을 설명",
      "requiredData": ["difficultyEvidence", "discriminationPoint"],
      "layout": "chart_or_distribution",
      "components": ["section_title", "difficulty_visual", "highlight_callout", "interpretation_note"],
      "assetPolicy": "검증된 구간·점수만 사용. 근거가 서술형이면 정량 차트로 바꾸지 않는다.",
      "qualityChecks": ["근거 없는 비율 없음", "변별 구간이 한 문장으로 설명됨", "색의 의미 일관"]
    },
    "overall_review": {
      "purpose": "시험의 핵심 특징과 학생 체감 포인트를 2~4개로 요약",
      "requiredData": ["reviewPoints"],
      "layout": "stacked_summary_panels",
      "components": ["section_title", "summary_panels", "emphasis_marks", "brand_footer"],
      "assetPolicy": "생성 가능. 긴 원문을 그대로 넣지 않고 검수된 요약문 사용.",
      "qualityChecks": ["패널당 한 메시지", "사실과 해석 구분", "과장 표현 없음"]
    },
    "key_question_summary": {
      "purpose": "선정한 주요문항과 선정 이유를 먼저 안내",
      "requiredData": ["questionIndex"],
      "layout": "stacked_summary_panels",
      "components": ["section_title", "question_chips", "selection_reasons", "brand_footer"],
      "assetPolicy": "문항 번호·배점은 코드 텍스트 우선.",
      "qualityChecks": ["뒤의 상세 카드와 번호 일치", "선정 이유 중복 없음", "2~5문항 이내"]
    },
    "key_question": {
      "purpose": "원본 문제와 핵심 개념·풀이 전략·오답 지점을 함께 설명",
      "requiredData": ["questionNumber", "sourceAssetId", "concepts", "strategy", "errorPoint"],
      "layout": "source_and_analysis_split",
      "components": ["question_label", "source_asset_frame", "analysis_panel", "concept_tags", "error_point"],
      "assetPolicy": "원본 문제 crop을 그대로 삽입. 수식·보기·도형을 이미지 모델이 다시 쓰지 않는다.",
      "qualityChecks": ["원본 crop 변형 없음", "문항 번호 일치", "개념·전략·오답이 서로 다른 정보"]
    },
    "solution": {
      "purpose": "검증된 풀이를 단계별로 보여 주고 핵심 판단을 강조",
      "requiredData": ["questionNumber", "solutionAssetId", "stepSummary", "answer"],
      "layout": "source_and_solution_split",
      "components": ["question_label", "solution_panel", "step_markers", "answer_check"],
      "assetPolicy": "손풀이/수식은 검증된 원본 이미지를 사용. 생성 모델은 주변 레이아웃만 담당.",
      "qualityChecks": ["답과 풀이 검산", "대응 주요문항 바로 뒤", "작은 수식 가독성 확보"]
    },
    "source_question": {
      "purpose": "시험 원안 또는 출처 문제 자체를 증거로 제시",
      "requiredData": ["sourceAssetId", "sourceCaption"],
      "layout": "full_source_asset",
      "components": ["source_asset_frame", "source_caption"],
      "assetPolicy": "원본 삽입 전용. 생성 금지.",
      "qualityChecks": ["출처·문항 번호 확인", "필요 영역만 안전하게 crop", "원본 비율 유지"]
    },
    "source_reference": {
      "purpose": "교재 표지·페이지·출처를 증거로 제시",
      "requiredData": ["sourceAssetId", "sourceCaption"],
      "layout": "book_or_reference",
      "components": ["source_asset_frame", "source_caption"],
      "assetPolicy": "제공된 표지/출처 이미지를 그대로 사용. 유사 표지를 생성하지 않는다.",
      "qualityChecks": ["실제 출처만 기재", "저작권 표기 보존", "과도한 확대·왜곡 없음"]
    },
    "data_reference": {
      "purpose": "내부 분석표·누적 비교표를 정확하게 표시",
      "requiredData": ["tableRows"],
      "layout": "data_table",
      "components": ["table_frame", "row_labels", "data_cells"],
      "assetPolicy": "HTML/SVG/Canvas 등 코드 렌더 우선. GPT Image 표 생성 금지.",
      "qualityChecks": ["행·열 합계 검산", "잘림 없음", "작은 글자 최소 크기 준수"]
    },
    "next_preparation": {
      "purpose": "다음 시험까지 실행할 우선순위 학습 행동을 제시",
      "requiredData": ["actionItems"],
      "layout": "checklist",
      "components": ["section_title", "action_checklist", "priority_highlight", "brand_footer"],
      "assetPolicy": "생성 가능. 확정된 교육 계획만 사용.",
      "qualityChecks": ["행동 문장으로 작성", "3~5개 이내", "시험 분석과 직접 연결"]
    },
    "academy_cta": {
      "purpose": "학원의 분석·관리 가치를 짧게 마무리",
      "requiredData": ["valueStatement", "contactOrNextAction"],
      "layout": "cta_photo",
      "components": ["brand_header", "photo_or_character", "value_statement", "cta_panel"],
      "assetPolicy": "생성 가능. 실제 학생처럼 오인될 합성 인물, 성과 보장 표현 금지.",
      "qualityChecks": ["한 가지 행동만 요청", "성과 과장 없음", "채널별 연락처 검수"]
    }
  }
}
